@bot.message_handler(content_types=['photo', 'text'])
def handle_all(message):
    uid = message.from_user.id
    user = db_get_user(uid)
    
    # --- АДМИН КОМАНДЫ ---
    if uid == ADMIN_ID and message.text:
        # 1. Просмотр списка всех заявок
        if message.text == "проверка":
            conn = sqlite3.connect('bot_data.db')
            cursor = conn.cursor()
            cursor.execute("SELECT uid FROM submissions")
            subs = cursor.fetchall()
            conn.close()
            if not subs: 
                bot.send_message(ADMIN_ID, "Нет активных заявок.")
                return
            bot.send_message(ADMIN_ID, "📝 Список заявок (ID пользователей):\n\n" + "\n".join([f"`{s[0]}`" for s in subs]), parse_mode="Markdown")
            return

        # 2. Одобрение заявки (одобрено ID)
        if message.text.startswith("одобрено "):
            try:
                target_id = int(message.text.split()[1])
                db_update_stars(target_id, 50)
                conn = sqlite3.connect('bot_data.db')
                conn.cursor().execute("DELETE FROM submissions WHERE uid = ?", (target_id,))
                conn.commit()
                conn.close()
                bot.send_message(target_id, "✅ Ваша заявка одобрена! Вы получили на баланс 50 ⭐ звезд.")
                bot.send_message(ADMIN_ID, f"✅ Заявка {target_id} одобрена, звезды выданы.")
            except Exception as e:
                bot.send_message(ADMIN_ID, f"❌ Ошибка: проверьте формат (одобрено 1234567)")
            return

        # 3. Просмотр фото конкретной заявки (просто ID)
        if message.text.isdigit():
            conn = sqlite3.connect('bot_data.db')
            cursor = conn.cursor()
            cursor.execute("SELECT photos FROM submissions WHERE uid = ?", (int(message.text),))
            res = cursor.fetchone()
            conn.close()
            if res:
                bot.send_message(ADMIN_ID, f"📸 Фото пользователя {message.text}:")
                for p in res[0].split(','): 
                    bot.send_photo(ADMIN_ID, p)
            else:
                bot.send_message(ADMIN_ID, "❌ Заявка с таким ID не найдена.")
            return

    # --- ЛОГИКА ПОЛЬЗОВАТЕЛЯ ---
    if user['step'] == 'wait_photos':
        if message.content_type != 'photo':
            bot.send_message(message.chat.id, "⚠️ Скидывайте только скриншоты (фото)!")
            return
        if uid not in photo_buffer: photo_buffer[uid] = []
        photo_buffer[uid].append(message.photo[-1].file_id)
        rem = 10 - len(photo_buffer[uid])
        if rem > 0:
            bot.send_message(message.chat.id, f"✅ Принято! Осталось еще {rem} скринов до проверки.")
        else:
            db_save_submission(uid, photo_buffer[uid])
            db_update_step(uid, 'main')
            bot.send_message(message.chat.id, "⌛ Ожидайте проверки модерации. После принятия Вы сразу же получите на баланс 50 ⭐ звезд.")
            bot.send_message(ADMIN_ID, f"🔔 Новая заявка на проверку! ID: `{uid}`\nНапиши его ID, чтобы увидеть фото, или `одобрено {uid}`, чтобы выдать звезды.", parse_mode="Markdown")

