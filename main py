def init_db():
    conn = sqlite3.connect('bot_data.db')
    cursor = conn.cursor()
    cursor.execute('''CREATE TABLE IF NOT EXISTS users 
                      (uid INTEGER PRIMARY KEY, name TEXT, stars INTEGER DEFAULT 0, step TEXT DEFAULT 'main')''')
    cursor.execute('''CREATE TABLE IF NOT EXISTS submissions 
                      (uid INTEGER PRIMARY KEY, photos TEXT)''')
    conn.commit()
    conn.close()

def db_get_user(uid, name="User"):
    conn = sqlite3.connect('bot_data.db')
    cursor = conn.cursor()
    cursor.execute("SELECT stars, step FROM users WHERE uid = ?", (uid,))
    res = cursor.fetchone()
    if not res:
        cursor.execute("INSERT INTO users (uid, name, stars, step) VALUES (?, ?, ?, ?)", (uid, name, 0, 'main'))
        conn.commit()
        res = (0, 'main')
    conn.close()
    return {'stars': res[0], 'step': res[1]}

def db_update_stars(uid, amount):
    conn = sqlite3.connect('bot_data.db')
    cursor = conn.cursor()
    cursor.execute("UPDATE users SET stars = stars + ? WHERE uid = ?", (amount, uid))
    conn.commit()
    conn.close()

def db_update_step(uid, step):
    conn = sqlite3.connect('bot_data.db')
    cursor = conn.cursor()
    cursor.execute("UPDATE users SET step = ? WHERE uid = ?", (step, uid))
    conn.commit()
    conn.close()

def db_save_submission(uid, photos_list):
    conn = sqlite3.connect('bot_data.db')
    cursor = conn.cursor()
    photos_str = ",".join(photos_list)
    cursor.execute("INSERT OR REPLACE INTO submissions (uid, photos) VALUES (?, ?)", (uid, photos_str))
    conn.commit()
    conn.close()

